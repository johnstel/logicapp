{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/contracts/pdf-ocr-output.schema.json",
  "title": "PDF OCR Logic App Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "status", "source", "workflow", "createdAt"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "status": { "type": "string", "enum": ["succeeded", "failed"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fileName", "contentType", "sizeBytes", "container", "blobName"],
      "properties": {
        "fileName": { "type": "string", "minLength": 1 },
        "contentType": { "type": "string", "minLength": 1 },
        "sizeBytes": { "type": "integer", "minimum": 0 },
        "container": { "type": "string", "minLength": 1 },
        "blobName": { "type": "string", "minLength": 1 },
        "etag": { "type": "string" },
        "contentHash": { "type": "string", "pattern": "^sha256:[A-Fa-f0-9]{64}$" }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "runId", "triggerName", "correlationId"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "runId": { "type": "string", "minLength": 1 },
        "triggerName": { "type": "string" },
        "correlationId": { "type": "string" }
      }
    },
    "ocr": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "operationId": { "type": "string" },
        "apiStatusCode": { "type": "integer", "minimum": 100, "maximum": 599 },
        "text": { "type": "string" },
        "pages": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["pageNumber"],
            "properties": {
              "pageNumber": { "type": "integer", "minimum": 1 },
              "text": { "type": "string" },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "retryable"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "UNSUPPORTED_MEDIA_TYPE",
            "EMPTY_FILE",
            "FILE_TOO_LARGE",
            "CORRUPT_OR_UNREADABLE_PDF",
            "PDF_OCR_WORKFLOW_FAILURE",
            "BLOB_READ_FAILED",
            "DOCUMENT_INTELLIGENCE_FAILED",
            "OUTPUT_WRITE_FAILED"
          ]
        },
        "message": { "type": "string", "minLength": 1 },
        "retryable": { "type": "boolean" },
        "details": { "type": "object" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "succeeded" } } },
      "then": {
        "required": ["ocr"],
        "properties": {
          "ocr": {
            "required": ["provider", "model", "operationId", "apiStatusCode", "text", "pages"],
            "properties": {
              "provider": { "const": "Azure AI Document Intelligence" },
              "model": { "const": "prebuilt-read" },
              "pages": { "type": "array" }
            }
          }
        },
        "not": { "required": ["error"] }
      }
    },
    {
      "if": { "properties": { "status": { "const": "failed" } } },
      "then": {
        "required": ["error"],
        "properties": {
          "ocr": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "provider": { "type": "string" },
              "model": { "type": "string" },
              "operationId": { "type": "string" }
            }
          }
        }
      }
    }
  ]
}
